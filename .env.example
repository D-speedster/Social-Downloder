# ============================================================
# Social-Downloader Bot Configuration
# Phase 1: Security-Enhanced Environment Variables
# ============================================================

# ============================================================
# CORE BOT CREDENTIALS (REQUIRED)
# ============================================================
# Main bot token from @BotFather
BOT_TOKEN=your_main_bot_token_here

# Delivery bot token for large files (optional, for bot2.py)
DELIVERY_BOT_TOKEN=your_delivery_bot_token_here

# Telegram API credentials from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here


# ============================================================
# ADMIN CONFIGURATION (SECURITY: FROM ENVIRONMENT)
# ============================================================
# Phase 1 Fix: Admin IDs now configured via environment variables
# Format: Comma-separated list of Telegram user IDs
# Example: ADMIN_IDS="123456789,987654321,555666777"
ADMIN_IDS=your_admin_id_here

# Single admin ID for error notifications (optional, will be auto-added to ADMIN_IDS)
ADMIN_ID=your_admin_id_here
NOTIFY_ADMIN_ON_ERROR=false


# ============================================================
# RAPIDAPI CONFIGURATION (UNIVERSAL DOWNLOADER)
# ============================================================
# RapidAPI key for social media downloads
# Get from: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here

# Phase 1 Fix: Rate limiting to prevent quota exhaustion
# Maximum API calls per time window
RAPIDAPI_RATE_LIMIT=30
RAPIDAPI_RATE_WINDOW=60


# ============================================================
# FILE PATHS CONFIGURATION (SECURE LOCATIONS)
# ============================================================
# Phase 1 Fix: Cookies stored in secure isolated directory
COOKIE_BASE_DIR=./data/cookies

# FFMPEG path for media processing
# Windows: C:\ffmpeg\bin\ffmpeg.exe
# Linux/Docker: ffmpeg (from PATH)
FFMPEG_PATH=ffmpeg


# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Database paths (platform-specific)
# Windows: C:\Users\YourUsername\Documents\Database
# Linux/Ubuntu: /var/lib/social-db/
# Default (relative): ./data/database
DB_BASE_PATH_WINDOWS=C:\Users\YourUsername\Documents\Database
DB_BASE_PATH_LINUX=/var/lib/social-db/
DB_BASE_PATH_DEFAULT=./data/database

# MySQL Configuration (optional, USE_MYSQL=False by default)
DB_HOST=localhost
DB_USER=admin
DB_PASSWORD=
DB_NAME=bot_db


# ============================================================
# TELEGRAM THROTTLING (PERFORMANCE TUNING)
# ============================================================
TELEGRAM_SLEEP_THRESHOLD=600
TELEGRAM_FLOOD_SLEEP_THRESHOLD=60
TELEGRAM_MAX_CONCURRENT=4
TELEGRAM_MAX_WORKERS=8
TELEGRAM_UPLOAD_DELAY_SMALL=0.0
TELEGRAM_UPLOAD_DELAY_MEDIUM=0.0
TELEGRAM_UPLOAD_DELAY_LARGE=0.1
TELEGRAM_RETRY_ATTEMPTS=2
TELEGRAM_BASE_RETRY_DELAY=0.5


# ============================================================
# YOUTUBE CONFIGURATION
# ============================================================
YOUTUBE_MAX_RETRIES=3
YOUTUBE_FILESIZE_CORRECTION_FACTOR=0.30


# ============================================================
# JOB RECOVERY
# ============================================================
RECOVER_JOBS_ON_STARTUP=false
RECOVERY_NOTIFY_USERS=false


# ============================================================
# PROXY CONFIGURATION (OPTIONAL)
# ============================================================
# Uncomment and configure if you need proxy for restricted networks
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080
# PROXY_USERNAME=
# PROXY_PASSWORD=
